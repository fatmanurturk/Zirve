# Application
APP_NAME=Zirve — Doğa Sporları Gönüllülük Platformu

# Security
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# JSON array form:
# BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# veya virgülle ayrılmış:
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ORIGINS=[]

# Database (SQLAlchemy async URL)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/zirve
